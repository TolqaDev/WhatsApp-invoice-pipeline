# ============================================================
#  Fatura Bot — Ortam Değişkenleri
#  Bu dosyayı .env olarak kopyalayın ve değerleri ayarlayın.
#  Detaylar: README.md → Yapılandırma bölümü
# ============================================================

# ─── Ortam ───────────────────────────────────────────────────
# production (varsayılan) | development
# Development: DEBUG log, auto-reload, görsel kaydetme aktif
# Production:  WARNING log, sıkı rate-limit
ENV=production

# ─── Gemini API ──────────────────────────────────────────────
# Ücretsiz anahtar: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here

# ─── Sunucu ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ─── CORS ────────────────────────────────────────────────────
# * = herkese açık | virgülle ayırarak belirli origin'ler
CORS_ORIGINS=*

# ─── Veri Dizinleri ──────────────────────────────────────────
EXCEL_DATA_DIR=public/daily
IMAGES_DIR=public/images

# ─── Görsel Kaydetme ─────────────────────────────────────────
# Debug için true yapılabilir (IMAGES_DIR'e kaydeder)
SAVE_IMAGES=false

# ─── Loglama ─────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Minimum güven skoru (altında uyarı ver ama yine de kaydet)
MIN_CONFIDENCE_WARN=60

# ─── TL Bazlı Bütçe Ayarları ─────────────────────────────────
# Aylık Gemini API bütçesi (TL) — aşılırsa yeni fiş kabul edilmez
MONTHLY_BUDGET_TL=200.0
# USD/TL kuru (bütçe hesaplaması için)
USD_TL_RATE=45.0

# ─── OCR-First Eşik Değerleri ─────────────────────────────────
# REJECT: Altında → fiş değil → reddedilir
OCR_REJECT_THRESHOLD=20
# SUFFICIENT: Üstünde → OCR tam çözdü → Gemini gereksiz (maliyet tasarrufu)
OCR_SUFFICIENT_THRESHOLD=70

# ─── Güvenlik ────────────────────────────────────────────────
# Boş bırakılırsa auth devre dışı kalır
API_SECRET=
RATE_LIMIT_RPM=30
