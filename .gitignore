# ============================================================
#  Fatura Bot — .gitignore
#  Python / FastAPI / Chrome Extension projesi
# ============================================================

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# Virtual Environments
venv/
.venv/
env/
ENV/

# Testing & Coverage
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# Type Checking & Linting
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
*.pem

# ─── Veri Çıktıları (Excel, Görseller, WA Auth) ─────────────
public/daily/*.xlsx
public/images/
public/whatsapp-auth/
public/*.xlsx

# ─── Chrome Extension (build artifacts) ──────────────────────
chrome-extension/*.crx
chrome-extension/*.pem
chrome-extension/icons/generate.html
web-ext-artifacts/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/

# ─── Database ────────────────────────────────────────────────
*.sqlite3
*.db

# ─── OS ──────────────────────────────────────────────────────
# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─── IDE / Editor ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── Misc ────────────────────────────────────────────────────
node_modules/
.temp/
tmp/
