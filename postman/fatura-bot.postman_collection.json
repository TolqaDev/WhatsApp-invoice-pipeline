        {
          "name": "Get Queue Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/queue-status",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "queue-status"]
            },
            "description": "Kuyruk ve aktif işlem durumu. Eşzamanlı işlenen fiş sayısı, bekleyen ve son işlem sayısı."
          },
          "response": [
            {
              "name": "Queue Status",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"active_processing\": 0,\n  \"pending\": 0,\n  \"recent_count\": 12,\n  \"max_recent\": 50\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Processing",
      "description": "Fiş görsel analizi — Ana işlem endpoint'i.",
      "item": [
        {
          "name": "Process Receipt Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image_base64\": \"{{testImageBase64}}\",\n  \"mime_type\": \"image/jpeg\",\n  \"sender\": \"postman-test\",\n  \"request_id\": \"test-001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/process-image",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "process-image"]
            },
            "description": "POS fiş görselini analiz eder ve Excel'e kaydeder.\n\n**İş Akışı:**\n1. Base64 decode & boyut kontrolü (max 10MB)\n2. OCR ön-filtre: Fiş mi? Yeterli mi?\n3. Gemini AI analizi (gerekirse)\n4. Doğrulama & güven skoru\n5. Excel'e kaydet\n\n**Body:**\n- `image_base64` (zorunlu): Görselin base64 verisi\n- `mime_type` (zorunlu): image/jpeg, image/png, image/webp, image/heic\n- `sender` (opsiyonel): Gönderen kaynak (varsayılan: chrome-extension)\n- `request_id` (opsiyonel): İstek takip ID\n- `timestamp` (opsiyonel): Unix timestamp (ms)\n\n**Hata Kodları:**\n- `IMAGE_TOO_LARGE`: Görsel 10MB'dan büyük\n- `INVALID_BASE64`: Geçersiz base64\n- `NOT_A_RECEIPT`: Görsel POS fişi değil\n- `BUDGET_EXCEEDED`: Aylık bütçe doldu (429)\n- `RATE_LIMITED`: Gemini rate limit (429)\n- `GEMINI_UNAVAILABLE`: AI servisi erişilemez (503)"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"row_number\": 5,\n  \"confidence\": 92,\n  \"source\": \"gemini\",\n  \"summary\": {\n    \"firma\": \"BİM\",\n    \"tarih\": \"15.03.2026\",\n    \"toplam\": 245.90,\n    \"masraf\": \"Market Alışverişi\",\n    \"odeme\": \"Nakit\"\n  },\n  \"excel_path\": \"public/daily\",\n  \"processing_time_ms\": 1830\n}"
            },
            {
              "name": "Not a Receipt",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"error_code\": \"NOT_A_RECEIPT\",\n  \"message\": \"Gönderilen görsel bir POS fişi olarak tanınamadı\",\n  \"prefilter_score\": 12,\n  \"prefilter_detail\": \"OCR metin çok kısa, fiş anahtar kelimesi bulunamadı\"\n}"
            },
            {
              "name": "Image Too Large",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"success\": false,\n  \"error_code\": \"IMAGE_TOO_LARGE\",\n  \"message\": \"Görsel çok büyük: 12.5MB (max 10MB)\"\n}"
            },
            {
              "name": "Budget Exceeded",
              "status": "Too Many Requests",
              "code": 429,
              "body": "{\n  \"success\": false,\n  \"error_code\": \"BUDGET_EXCEEDED\",\n  \"message\": \"Aylık bütçe doldu (₺200.00/₺200.00).\"\n}"
            },
            {
              "name": "Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"error_code\": \"UNAUTHORIZED\",\n  \"message\": \"Geçersiz veya eksik API anahtarı\"\n}"
            }
          ]
        }
      ]
    },
