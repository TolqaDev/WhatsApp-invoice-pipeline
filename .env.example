# ============================================================
#  Fatura Bot — Ortam Değişkenleri (.env.example)
#  Bu dosyayı .env olarak kopyalayın ve değerleri ayarlayın.
#  ÖNEMLİ: Gerçek anahtarlarınızı repoya commit etmeyin.
# ============================================================

# ─── Ortam ───────────────────────────────────────────────────
# production | development
ENV=production

# ─── Ortak Güvenlik ──────────────────────────────────────────
# Zorunlu — Python API, Node bridge ve Chrome extension hepsi
# aynı API_SECRET değerini kullanır. En az 32 karakter önerilir.
API_SECRET=
# IP başına dakikada izin verilen istek sayısı
RATE_LIMIT_RPM=30

# ─── Python API (FastAPI :3000) ──────────────────────────────
# Python sunucusunun dinlediği host/port
HOST=0.0.0.0
PORT=3000
# Node bridge'in Python API'ye eriştiği tam URL
# 0.0.0.0 ise localhost kullanılır, uzak sunucu ise IP/domain yazın
PYTHON_API_URL=http://localhost:3000

# Gemini AI — ücretsiz anahtar: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# CORS — * = herkese açık | virgülle ayırarak belirli origin'ler
CORS_ORIGINS=*

# Veri dizinleri (proje köküne göre)
EXCEL_DATA_DIR=public/daily
IMAGES_DIR=public/images
SAVE_IMAGES=false

# Loglama — DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
MIN_CONFIDENCE_WARN=60

# Bütçe
MONTHLY_BUDGET_TL=200.0
USD_TL_RATE=45.0

# OCR eşikleri
# < REJECT   → fiş değil, reddedilir
# ≥ SUFFICIENT → OCR yeterli, Gemini çağrılmaz (maliyet tasarrufu)
OCR_REJECT_THRESHOLD=20
OCR_SUFFICIENT_THRESHOLD=70

# ─── WhatsApp Baileys Bridge (Node.js :3001) ─────────────────
# Bridge'in tam adresi — Python proxy ve Extension bu URL ile bağlanır
WHATSAPP_BRIDGE_URL=http://localhost:3001

# Sadece bu numaralardan gelen görseller işlenir (virgülle ayrılmış)
# Boş = tüm numaralara izin (üretimde mutlaka doldurun)
ALLOW_JID=

# QR kod ve bildirim zamanlayıcı (saniye)
QR_REFRESH_INTERVAL=30
NOTIFICATION_MUTE_INTERVAL=30

# ─── Chrome Extension Ayarları ───────────────────────────────
# Extension popup'tan girilir, .env'den okunmaz.
# Referans:
#   Python API URL  → PYTHON_API_URL değeri  (ör. http://localhost:3000)
#   WhatsApp URL    → WHATSAPP_BRIDGE_URL    (ör. http://localhost:3001)
#   API Key         → API_SECRET değeri
